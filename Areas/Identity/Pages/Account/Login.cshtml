@page
@model LoginModel

@{
    ViewData["Title"] = "Login";
}

<div class="row justify-content-center">
    <div class="col-12 col-lg-10">
        <div class="row g-4">
            <div class="col-12 col-lg-6">
                <section class="auth-shell h-100">
                    <h1 class="section-title mb-2">@ViewData["Title"]</h1>
                    <p class="section-subtitle mb-4">Sign in to manage your events, builds, and community content.</p>

                    <form id="account" method="post" class="auth-form">
                        <div asp-validation-summary="All" class="text-danger mb-3"></div>

                        <div class="mb-3">
                            <label asp-for="Input.Email" class="form-label"></label>
                            <input asp-for="Input.Email" class="form-control" autocomplete="username" />
                            <span asp-validation-for="Input.Email" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Input.Password" class="form-label"></label>
                            <input asp-for="Input.Password" class="form-control" autocomplete="current-password" />
                            <span asp-validation-for="Input.Password" class="text-danger"></span>
                        </div>

                        <div class="form-check mb-4">
                            <input asp-for="Input.RememberMe" class="form-check-input" />
                            <label asp-for="Input.RememberMe" class="form-check-label">
                                @Html.DisplayNameFor(m => m.Input.RememberMe)
                            </label>
                        </div>

                        <button type="submit" class="btn app-btn app-btn-primary w-100">Login</button>

                        <div class="auth-links mt-4">
                            <a id="forgot-password" asp-page="./ForgotPassword">Forgot your password?</a>
                            <a asp-page="./Register" asp-route-returnUrl="@Model.ReturnUrl">Create a new account</a>
                        </div>
                    </form>
                </section>
            </div>

            <div class="col-12 col-lg-6">
                <section class="auth-shell h-100">
                    <h2 class="section-title h4 mb-2">External login</h2>
                    <p class="section-subtitle mb-4">Use another service to sign in.</p>

                    @if ((Model.ExternalLogins?.Count ?? 0) == 0)
                    {
                        <div class="empty-state-text">
                            External authentication is not configured for this application yet.
                        </div>
                    }
                    else
                    {
                        <form id="external-account"
                              asp-page="./ExternalLogin"
                              asp-route-returnUrl="@Model.ReturnUrl"
                              method="post">
                            <div class="external-login-list">
                                @foreach (var provider in Model.ExternalLogins)
                                {
                                    <button type="submit"
                                            class="btn btn-outline-primary w-100"
                                            name="provider"
                                            value="@provider.Name"
                                            title="Log in using your @provider.DisplayName account">
                                        Continue with @provider.DisplayName
                                    </button>
                                }
                            </div>
                        </form>
                    }
                </section>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
