@model WarbandOfTheSpiritborn.Models.Blog

@{
    ViewData["Title"] = "Delete blog post";
}

<div class="row justify-content-center">
    <div class="col-12 col-lg-8">
        <section class="form-shell">
            <h1 class="section-title mb-2">Delete blog post</h1>
            <p class="section-subtitle mb-4">This action cannot be undone.</p>

            <div class="content-shell mb-4">
                <h2 class="h4 mb-2">@Model.BlogName</h2>
                <div class="blog-meta mb-3">
                    <span>@Model.BlogAuthor</span>
                    <span>•</span>
                    <span>@Model.ArticleDate.ToString("dd MMM yyyy")</span>
                </div>
                <p class="mb-0">Are you sure you want to delete this post?</p>
            </div>

            <form asp-action="Delete">
                <input asp-for="Id" type="hidden" />

                <div class="d-flex flex-column flex-sm-row gap-3">
                    <button type="submit" class="btn app-btn app-btn-primary">Delete post</button>
                    <a asp-action="Index" class="btn btn-outline-primary">Cancel</a>
                </div>
            </form>
        </section>
    </div>
</div>