@model WarbandOfTheSpiritborn.Models.Blog

@{
    ViewData["Title"] = "Edit blog post";
}

<div class="row justify-content-center">
    <div class="col-12 col-xl-10">
        <section class="form-shell">
            <div class="d-flex flex-column flex-lg-row justify-content-between align-items-lg-center mb-4 gap-3">
                <div>
                    <h1 class="section-title mb-2">Edit blog post</h1>
                    <p class="section-subtitle mb-0">Refine the content, update the date, or improve the wording.</p>
                </div>

                <div class="d-flex gap-2 flex-wrap">
                    <a asp-action="Details" asp-route-id="@Model.Id" class="btn btn-outline-primary">View post</a>
                    <a asp-action="Index" class="btn btn-outline-primary">Back to blog</a>
                </div>
            </div>

            <form asp-action="Edit" method="post" class="blog-editor-form">
                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
                <input asp-for="Id" type="hidden" />

                <div class="mb-3">
                    <label asp-for="BlogName" class="form-label"></label>
                    <input asp-for="BlogName" class="form-control" placeholder="Enter a strong post title" />
                    <span asp-validation-for="BlogName" class="text-danger"></span>
                </div>

                <div class="row g-3 mb-3">
                    <div class="col-12 col-md-6">
                        <label asp-for="BlogAuthor" class="form-label"></label>
                        <input asp-for="BlogAuthor" class="form-control" placeholder="Author name" />
                        <span asp-validation-for="BlogAuthor" class="text-danger"></span>
                    </div>

                    <div class="col-12 col-md-6">
                        <label asp-for="ArticleDate" class="form-label"></label>
                        <input asp-for="ArticleDate" class="form-control" type="date" />
                        <span asp-validation-for="ArticleDate" class="text-danger"></span>
                    </div>
                </div>

                <div class="mb-4">
                    <label asp-for="BlogPost" class="form-label"></label>
                    <input asp-for="BlogPost" type="hidden" />
                    <div id="blog-editor" class="blog-quill-editor">@Html.Raw(Model.BlogPost)</div>
                    <span asp-validation-for="BlogPost" class="text-danger"></span>
                </div>

                <div class="d-flex flex-column flex-sm-row gap-3">
                    <button type="submit" class="btn app-btn app-btn-primary">Save changes</button>
                    <a asp-action="Delete" asp-route-id="@Model.Id" class="btn btn-outline-primary">Delete post</a>
                    <a asp-action="Index" class="btn btn-outline-primary">Cancel</a>
                </div>
            </form>
        </section>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />

    <link href="https://cdn.jsdelivr.net/npm/quill@1.3.7/dist/quill.snow.css" rel="stylesheet" />
    <script src="https://cdn.jsdelivr.net/npm/quill@1.3.7/dist/quill.min.js"></script>

    <script>
        const quill = new Quill('#blog-editor', {
            theme: 'snow',
            placeholder: 'Update your post...',
            modules: {
                toolbar: [
                    [{ header: [1, 2, 3, false] }],
                    ['bold', 'italic', 'underline', 'strike'],
                    [{ list: 'ordered' }, { list: 'bullet' }],
                    ['blockquote', 'code-block'],
                    ['link'],
                    [{ align: [] }],
                    ['clean']
                ]
            }
        });

        const form = document.querySelector('.blog-editor-form');
        const blogPostInput = document.querySelector('input[name="BlogPost"]');

        form.addEventListener('submit', function () {
            blogPostInput.value = quill.root.innerHTML;
        });
    </script>
}